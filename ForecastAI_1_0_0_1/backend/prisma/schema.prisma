generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ImportBatch {
  id                     String             @id @default(uuid()) @map("cr5c7_ImportBatchId")
  batchName              String?            @map("cr5c7_BatchName")
  currentTotal           Decimal?           @map("cr5c7_CurrentTotal")
  currentTotalBase       Decimal?           @map("cr5c7_currenttotal_Base")
  fileName               String?            @map("cr5c7_FileName")
  importDate             DateTime?          @map("cr5c7_ImportDate")
  importMonth            Int?               @map("cr5c7_ImportMonth")
  importYear             Int?               @map("cr5c7_ImportYear")
  lastTotal              Decimal?           @map("cr5c7_LastTotal")
  lastTotalBase          Decimal?           @map("cr5c7_lasttotal_Base")
  status                 Int?               @map("cr5c7_Status")
  variance               Decimal?           @map("cr5c7_Variance")
  varianceBase           Decimal?           @map("cr5c7_variance_Base")
  createdBy              String?            @map("CreatedBy")
  createdOn              DateTime?          @map("CreatedOn")
  createdOnBehalfBy      String?            @map("CreatedOnBehalfBy")
  exchangeRate           Decimal?           @map("ExchangeRate")
  importSequenceNumber   Int?               @map("ImportSequenceNumber")
  modifiedBy             String?            @map("ModifiedBy")
  modifiedOn             DateTime?          @map("ModifiedOn")
  modifiedOnBehalfBy     String?            @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime?          @map("OverriddenCreatedOn")
  ownerId                String             @map("OwnerId")
  owningBusinessUnit     String?            @map("OwningBusinessUnit")
  owningTeam             String?            @map("OwningTeam")
  owningUser             String?            @map("OwningUser")
  statecode              Int                @map("statecode")
  statuscode             Int?               @map("statuscode")
  timeZoneRuleVersionNumber Int?            @map("TimeZoneRuleVersionNumber")
  transactionCurrencyId  String?            @map("TransactionCurrencyId")
  utcConversionTimeZoneCode Int?            @map("UTCConversionTimeZoneCode")

  monthlyRevenues        MonthlyRevenue[]   @relation("BatchMonthlyRevenue")
  submissionSummaries    SubmissionSummary[] @relation("BatchSubmissionSummary")

  @@map("cr5c7_importbatch")
}

model MonthlyRevenue {
  id                 String            @id @default(uuid()) @map("cr5c7_MonthlyRevenueId")
  name               String?           @map("cr5c7_MonthlyRevenueName")
  amount             Decimal?          @map("cr5c7_Amount")
  amountBase         Decimal?          @map("cr5c7_amount_Base")
  batchId            String            @map("cr5c7_Batch")
  isEstimated        Boolean?          @map("cr5c7_IsEstimated")
  locked             Boolean?          @map("cr5c7_Locked")
  month              Int               @map("cr5c7_Month")
  projectId          String            @map("cr5c7_Project")
  type               Int?              @map("cr5c7_Type")
  year               Int               @map("cr5c7_Year")
  createdBy          String?           @map("CreatedBy")
  createdOn          DateTime?         @map("CreatedOn")
  createdOnBehalfBy  String?           @map("CreatedOnBehalfBy")
  exchangeRate       Decimal?          @map("ExchangeRate")
  importSequenceNumber Int?            @map("ImportSequenceNumber")
  modifiedBy         String?           @map("ModifiedBy")
  modifiedOn         DateTime?         @map("ModifiedOn")
  modifiedOnBehalfBy String?           @map("ModifiedOnBehalfBy")
  overriddenCreatedOn DateTime?        @map("OverriddenCreatedOn")
  ownerId            String            @map("OwnerId")
  owningBusinessUnit String?           @map("OwningBusinessUnit")
  owningTeam         String?           @map("OwningTeam")
  owningUser         String?           @map("OwningUser")
  statecode          Int               @map("statecode")
  statuscode         Int?              @map("statuscode")
  timeZoneRuleVersionNumber Int?        @map("TimeZoneRuleVersionNumber")
  transactionCurrencyId String?         @map("TransactionCurrencyId")
  utcConversionTimeZoneCode Int?        @map("UTCConversionTimeZoneCode")

  batch              ImportBatch      @relation(fields: [batchId], references: [id], name: "BatchMonthlyRevenue")
  project            ProjectMaster    @relation(fields: [projectId], references: [id], name: "ProjectMonthlyRevenue")

  @@map("cr5c7_monthlyrevenue")
}

model ProjectMaster {
  projectId                 String?            @unique @map("cr5c7_ProjectIDNumber")
  id                        String             @id @default(uuid()) @map("cr5c7_ProjectMasterId")
  businessUnit              String?            @map("cr5c7_BusinessUnitDescription")
  category                  String?            @map("cr5c7_Category")
  customerDescription       String?            @map("cr5c7_CustomerDescription")
  customerId                String?            @map("cr5c7_CustomerID")
  edlId                     String?            @map("cr5c7_EDLID")
  edlName                   String?            @map("cr5c7_EDLName")
  janPPM                    String?            @map("cr5c7_JanPPM")
  market                    String?            @map("cr5c7_MarketsDescription")
  marketUnit                String?            @map("cr5c7_MarketUnitDescription")
  opportunityId             String?            @map("cr5c7_OpportunityID")
  opportunityName           String?            @map("cr5c7_OpportunityName")
  parentCustomer            String?            @map("cr5c7_ParentCustomer")
  pdlId                     String?            @map("cr5c7_PDLID")
  pdlName                   String?            @map("cr5c7_PDLName")
  pmId                      String?            @map("cr5c7_PMID")
  pmName                    String?            @map("cr5c7_PMName")
  projectBillability        String?            @map("cr5c7_ProjectBillability")
  projectDescription        String?            @map("cr5c7_ProjectDescription")
  projectEndDate            DateTime          @map("cr5c7_ProjectEndDate")
  soId                      String?            @map("cr5c7_SOID")
  subPractice               String?            @map("cr5c7_SubPracticeDesc")
  tower                     String?            @map("cr5c7_Tower")
  vertical                  String?            @map("cr5c7_VerticalDescription")
  createdBy                 String?            @map("CreatedBy")
  createdOn                 DateTime?         @map("CreatedOn")
  createdOnBehalfBy         String?            @map("CreatedOnBehalfBy")
  importSequenceNumber      Int?               @map("ImportSequenceNumber")
  modifiedBy                String?            @map("ModifiedBy")
  modifiedOn                DateTime?         @map("ModifiedOn")
  modifiedOnBehalfBy        String?            @map("ModifiedOnBehalfBy")
  overriddenCreatedOn       DateTime?         @map("OverriddenCreatedOn")
  ownerId                   String             @map("OwnerId")
  owningBusinessUnit        String?            @map("OwningBusinessUnit")
  owningTeam                String?            @map("OwningTeam")
  owningUser                String?            @map("OwningUser")
  statecode                 Int                @map("statecode")
  statuscode                Int?               @map("statuscode")
  timeZoneRuleVersionNumber Int?               @map("TimeZoneRuleVersionNumber")
  utcConversionTimeZoneCode Int?               @map("UTCConversionTimeZoneCode")

  monthlyRevenues           MonthlyRevenue[]   @relation("ProjectMonthlyRevenue")
  submissionSummaries       SubmissionSummary[] @relation("ProjectSubmissionSummary")

  @@map("cr5c7_projectmaster")
}

model SubmissionSummary {
  id                     String          @id @default(uuid()) @map("cr5c7_SubmissionSummaryId")
  name                   String?         @map("cr5c7_SubmissionSummaryName")
  batchId                String          @map("cr5c7_Batch")
  currentTotal           Decimal?        @map("cr5c7_CurrentTotal")
  currentTotalBase       Decimal?        @map("cr5c7_currenttotal_Base")
  lastTotal              Decimal?        @map("cr5c7_LastTotal")
  lastTotalBase          Decimal?        @map("cr5c7_lasttotal_Base")
  projectId              String          @map("cr5c7_Project")
  trend                  Int?            @map("cr5c7_Trend")
  variance               Decimal?        @map("cr5c7_Variance")
  varianceBase           Decimal?        @map("cr5c7_variance_Base")
  variance1              Decimal?        @map("cr5c7_Variance1")
  createdBy              String?         @map("CreatedBy")
  createdOn              DateTime?       @map("CreatedOn")
  createdOnBehalfBy      String?         @map("CreatedOnBehalfBy")
  exchangeRate           Decimal?        @map("ExchangeRate")
  importSequenceNumber   Int?            @map("ImportSequenceNumber")
  modifiedBy             String?         @map("ModifiedBy")
  modifiedOn             DateTime?       @map("ModifiedOn")
  modifiedOnBehalfBy     String?         @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime?       @map("OverriddenCreatedOn")
  ownerId                String          @map("OwnerId")
  owningBusinessUnit     String?         @map("OwningBusinessUnit")
  owningTeam             String?         @map("OwningTeam")
  owningUser             String?         @map("OwningUser")
  statecode              Int             @map("statecode")
  statuscode             Int?            @map("statuscode")
  timeZoneRuleVersionNumber Int?         @map("TimeZoneRuleVersionNumber")
  transactionCurrencyId  String?         @map("TransactionCurrencyId")
  utcConversionTimeZoneCode Int?         @map("UTCConversionTimeZoneCode")

  batch                  ImportBatch     @relation(fields: [batchId], references: [id], name: "BatchSubmissionSummary")
  project                ProjectMaster   @relation(fields: [projectId], references: [id], name: "ProjectSubmissionSummary")

  @@map("cr5c7_submissionsummary")
}

model Customer {
  id                     String   @id @default(uuid()) @map("mbg_Customer1Id")
  name                   String   @map("mbg_CustomerName")
  createdBy              String?  @map("CreatedBy")
  createdOn              DateTime? @map("CreatedOn")
  createdOnBehalfBy      String?  @map("CreatedOnBehalfBy")
  importSequenceNumber   Int?     @map("ImportSequenceNumber")
  modifiedBy             String?  @map("ModifiedBy")
  modifiedOn             DateTime? @map("ModifiedOn")
  modifiedOnBehalfBy     String?  @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime? @map("OverriddenCreatedOn")
  ownerId                String   @map("OwnerId")
  owningBusinessUnit     String?  @map("OwningBusinessUnit")
  owningTeam             String?  @map("OwningTeam")
  owningUser             String?  @map("OwningUser")
  statecode              Int      @map("statecode")
  statuscode             Int?     @map("statuscode")
  timeZoneRuleVersionNumber Int?  @map("TimeZoneRuleVersionNumber")
  utcConversionTimeZoneCode Int?  @map("UTCConversionTimeZoneCode")

  @@map("mbg_customer1")
}


model SalesOrder {
  id                     String   @id @default(uuid()) @map("mbg_SalesOrderId")
  salesOrderNumber       String   @map("mbg_SalesOrderNumber")
  createdBy              String?  @map("CreatedBy")
  createdOn              DateTime? @map("CreatedOn")
  createdOnBehalfBy      String?  @map("CreatedOnBehalfBy")
  importSequenceNumber   Int?     @map("ImportSequenceNumber")
  modifiedBy             String?  @map("ModifiedBy")
  modifiedOn             DateTime? @map("ModifiedOn")
  modifiedOnBehalfBy     String?  @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime? @map("OverriddenCreatedOn")
  ownerId                String   @map("OwnerId")
  owningBusinessUnit     String?  @map("OwningBusinessUnit")
  owningTeam             String?  @map("OwningTeam")
  owningUser             String?  @map("OwningUser")
  statecode              Int      @map("statecode")
  statuscode             Int?     @map("statuscode")
  timeZoneRuleVersionNumber Int?  @map("TimeZoneRuleVersionNumber")
  utcConversionTimeZoneCode Int?  @map("UTCConversionTimeZoneCode")

  @@map("mbg_salesorder")
}

model Submission {
  id                     String     @id @default(uuid()) @map("mbg_SubmissionId")
  name                   String     @map("mbg_SubmissionName")
  financialYear          String     @map("mbg_FinancialYear")
  projectId              String     @map("mbg_Project")
  status                 Int        @map("mbg_Status")
  submissionDate         DateTime?  @map("mbg_SubmissionDate")
  submittedById          String?    @map("mbg_SubmittedBy")
  totalValue             Decimal?   @map("mbg_TotalValue")
  totalValueBase         Decimal?   @map("mbg_totalvalue_Base")
  type                   Int        @map("mbg_Type")
  createdBy              String?    @map("CreatedBy")
  createdOn              DateTime?  @map("CreatedOn")
  createdOnBehalfBy      String?    @map("CreatedOnBehalfBy")
  exchangeRate           Decimal?   @map("ExchangeRate")
  importSequenceNumber   Int?       @map("ImportSequenceNumber")
  modifiedBy             String?    @map("ModifiedBy")
  modifiedOn             DateTime?  @map("ModifiedOn")
  modifiedOnBehalfBy     String?    @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime?  @map("OverriddenCreatedOn")
  ownerId                String     @map("OwnerId")
  owningBusinessUnit     String?    @map("OwningBusinessUnit")
  owningTeam             String?    @map("OwningTeam")
  owningUser             String?    @map("OwningUser")
  statecode              Int        @map("statecode")
  statuscode             Int?       @map("statuscode")
  timeZoneRuleVersionNumber Int?    @map("TimeZoneRuleVersionNumber")
  transactionCurrencyId  String?    @map("TransactionCurrencyId")
  utcConversionTimeZoneCode Int?    @map("UTCConversionTimeZoneCode")

  submittedBy            ResourcePerson? @relation(fields: [submittedById], references: [id], name: "SubmissionSubmittedBy")

  @@map("mbg_submission")
}

model RevenueRecord {
  id                     String    @id @default(uuid()) @map("mbg_RevenueRecordId")
  actualAmount           Decimal?  @map("mbg_ActualAmount")
  actualAmountBase       Decimal?  @map("mbg_actualamount_Base")
  currentSubmissionAmount Decimal? @map("mbg_CurrentSubmissionAmount")
  currentSubmissionAmountBase Decimal? @map("mbg_currentsubmissionamount_Base")
  financialYear          String    @map("mbg_FinancialYear")
  forecastAmount         Decimal?  @map("mbg_ForecastAmount")
  forecastAmountBase     Decimal?  @map("mbg_forecastamount_Base")
  isAutoEstimated        Boolean?  @map("mbg_IsAutoEstimated")
  isLocked               Boolean?  @map("mbg_IsLocked")
  lastSubmissionAmount   Decimal?  @map("mbg_LastSubmissionAmount")
  lastSubmissionAmountBase Decimal? @map("mbg_lastsubmissionamount_Base")
  monthName              String    @map("mbg_MonthName")
  monthNumber            Int       @map("mbg_MonthNumber")
  projectId              String    @map("mbg_Project")
  reason                 String?   @map("mbg_Reason")
  varianceAmount         Decimal?  @map("mbg_VarianceAmount")
  varianceAmountBase     Decimal?  @map("mbg_varianceamount_Base")
  createdBy              String?   @map("CreatedBy")
  createdOn              DateTime? @map("CreatedOn")
  createdOnBehalfBy      String?   @map("CreatedOnBehalfBy")
  exchangeRate           Decimal?  @map("ExchangeRate")
  importSequenceNumber   Int?      @map("ImportSequenceNumber")
  modifiedBy             String?   @map("ModifiedBy")
  modifiedOn             DateTime? @map("ModifiedOn")
  modifiedOnBehalfBy     String?   @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime? @map("OverriddenCreatedOn")
  ownerId                String    @map("OwnerId")
  owningBusinessUnit     String?   @map("OwningBusinessUnit")
  owningTeam             String?   @map("OwningTeam")
  owningUser             String?   @map("OwningUser")
  statecode              Int       @map("statecode")
  statuscode             Int?      @map("statuscode")
  timeZoneRuleVersionNumber Int?   @map("TimeZoneRuleVersionNumber")
  transactionCurrencyId  String?   @map("TransactionCurrencyId")
  utcConversionTimeZoneCode Int?   @map("UTCConversionTimeZoneCode")

  @@map("mbg_revenuerecord")
}

model OrgStructure {
  id                     String   @id @default(uuid()) @map("mbg_OrgStructureId")
  bu                     String?  @map("mbg_BU")
  category               String?  @map("mbg_Category")
  market                 String?  @map("mbg_Market")
  name                   String   @map("mbg_OrgStructureName")
  subPractice            String?  @map("mbg_SubPractice")
  tower                  String?  @map("mbg_Tower")
  vertical               String?  @map("mbg_Vertical")
  createdBy              String?  @map("CreatedBy")
  createdOn              DateTime? @map("CreatedOn")
  createdOnBehalfBy      String?  @map("CreatedOnBehalfBy")
  importSequenceNumber   Int?     @map("ImportSequenceNumber")
  modifiedBy             String?  @map("ModifiedBy")
  modifiedOn             DateTime? @map("ModifiedOn")
  modifiedOnBehalfBy     String?  @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime? @map("OverriddenCreatedOn")
  ownerId                String   @map("OwnerId")
  owningBusinessUnit     String?  @map("OwningBusinessUnit")
  owningTeam             String?  @map("OwningTeam")
  owningUser             String?  @map("OwningUser")
  statecode              Int      @map("statecode")
  statuscode             Int?     @map("statuscode")
  timeZoneRuleVersionNumber Int?  @map("TimeZoneRuleVersionNumber")
  utcConversionTimeZoneCode Int?  @map("UTCConversionTimeZoneCode")

  @@map("mbg_orgstructure")
}

model ResourcePerson {
  id                     String     @id @default(uuid()) @map("mbg_ResourcePersonId")
  email                  String?    @map("mbg_Email")
  fullName               String     @map("mbg_FullName")
  phone                  String?    @map("mbg_Phone")
  createdBy              String?    @map("CreatedBy")
  createdOn              DateTime?  @map("CreatedOn")
  createdOnBehalfBy      String?    @map("CreatedOnBehalfBy")
  importSequenceNumber   Int?       @map("ImportSequenceNumber")
  modifiedBy             String?    @map("ModifiedBy")
  modifiedOn             DateTime?  @map("ModifiedOn")
  modifiedOnBehalfBy     String?    @map("ModifiedOnBehalfBy")
  overriddenCreatedOn    DateTime?  @map("OverriddenCreatedOn")
  ownerId                String     @map("OwnerId")
  owningBusinessUnit     String?    @map("OwningBusinessUnit")
  owningTeam             String?    @map("OwningTeam")
  owningUser             String?    @map("OwningUser")
  statecode              Int        @map("statecode")
  statuscode             Int?       @map("statuscode")
  timeZoneRuleVersionNumber Int?    @map("TimeZoneRuleVersionNumber")
  utcConversionTimeZoneCode Int?    @map("UTCConversionTimeZoneCode")

  submissions            Submission[] @relation("SubmissionSubmittedBy")

  @@map("mbg_resourceperson")
}
